{
  "name": "gsea",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--de-results",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "DESeq2 结果 CSV 文件。",
        "en": "DESeq2 results CSV file."
      }
    },
    {
      "name": "-s, --species",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "物种名称 (例如 'Homo sapiens')。",
        "en": "Species name (e.g. 'Homo sapiens')."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出目录。",
        "en": "Output directory."
      }
    },
    {
      "name": "--gene-sets",
      "type": "string",
      "required": false,
      "default": "KEGG_2021_Human",
      "description": {
        "zh": "基因集库 (例如 KEGG_2021_Human, GO_Biological_Process_2021)。",
        "en": "Gene sets library (e.g. KEGG_2021_Human, GO_Biological_Process_2021)."
      }
    },
    {
      "name": "--ranking-metric",
      "type": "string",
      "required": false,
      "default": "auto",
      "description": {
        "zh": "排名列 (auto, stat, log2FoldChange)。",
        "en": "Column for ranking (auto, stat, log2FoldChange)."
      }
    },
    {
      "name": "--top-n",
      "type": "int",
      "required": false,
      "default": "5",
      "description": {
        "zh": "绘制的顶部通路数量。",
        "en": "Number of top pathways to plot."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "default",
      "description": {
        "zh": "绘图主题。",
        "en": "Plot theme."
      }
    }
  ]
}