{
  "name": "qc",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "-i, --input",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入目录 (原始 FastQ)。",
        "en": "Input directory (raw FastQ)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出目录。",
        "en": "Output directory."
      }
    },
    {
      "name": "-t, --threads",
      "type": "int",
      "required": false,
      "default": "4",
      "description": {
        "zh": "线程数。",
        "en": "Number of threads."
      }
    },
    {
      "name": "--skip-qc",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "跳过 FastQC/fastp 统计。",
        "en": "Skip FastQC/fastp stats."
      }
    },
    {
      "name": "--skip-trim",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "跳过修剪。",
        "en": "Skip trimming."
      }
    },
    {
      "name": "--qualified-quality-phred",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "碱基合格的质量值。",
        "en": "Phred quality threshold."
      }
    },
    {
      "name": "--unqualified-percent-limit",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "允许的不合格碱基百分比。",
        "en": "Unqualified percent limit."
      }
    },
    {
      "name": "--n-base-limit",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "允许的 N 碱基数量。",
        "en": "N base limit."
      }
    },
    {
      "name": "--length-required",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "所需的最小长度。",
        "en": "Length required."
      }
    },
    {
      "name": "--adapter-sequence",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "read1 的接头序列。",
        "en": "Adapter sequence R1."
      }
    },
    {
      "name": "--adapter-sequence-r2",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "read2 的接头序列。",
        "en": "Adapter sequence R2."
      }
    },
    {
      "name": "--dedup",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "启用去重。",
        "en": "Enable deduplication."
      }
    }
  ]
}
