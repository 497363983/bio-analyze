{
  "name": "quant",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "-i, --input",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含 clean FastQ 文件的目录。",
        "en": "Directory with clean FastQ files."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出目录。",
        "en": "Output directory."
      }
    },
    {
      "name": "--fasta",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "基因组/转录组 FASTA 文件。",
        "en": "Genome/Transcriptome FASTA file."
      }
    },
    {
      "name": "--gtf",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "基因组 GTF 文件 (如果 FASTA 是转录组则可选)。",
        "en": "Genome GTF file (optional if FASTA is transcriptome)."
      }
    },
    {
      "name": "-t, --threads",
      "type": "int",
      "required": false,
      "default": "4",
      "description": {
        "zh": "线程数。",
        "en": "Number of threads."
      }
    }
  ]
}