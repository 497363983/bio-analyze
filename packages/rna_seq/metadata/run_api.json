{
  "name": "run",
  "type": "api",
  "description": {
    "zh": "运行 RNA-Seq 分析流程。",
    "en": "Run RNA-Seq Analysis Pipeline."
  },
  "params": [
    {
      "name": "input_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含原始 FastQ 文件的目录。",
        "en": "Directory containing raw FastQ files."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "分析结果输出目录。",
        "en": "Output directory for analysis results."
      }
    },
    {
      "name": "design_file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "实验设计 CSV 文件路径。",
        "en": "Path to experimental design CSV file."
      }
    },
    {
      "name": "species",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "物种名称 (例如 \"Homo sapiens\")。",
        "en": "Species name (e.g. \"Homo sapiens\")."
      }
    },
    {
      "name": "genome_fasta",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "参考基因组 FASTA 文件路径。",
        "en": "Path to reference genome FASTA file."
      }
    },
    {
      "name": "genome_gtf",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "基因组注释 GTF 文件路径。",
        "en": "Path to genome annotation GTF file."
      }
    },
    {
      "name": "threads",
      "type": "int",
      "required": false,
      "default": "4",
      "description": {
        "zh": "并行线程数 (默认: 4)。",
        "en": "Number of parallel threads (default: 4)."
      }
    },
    {
      "name": "skip_qc",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "跳过质量控制步骤。",
        "en": "Skip quality control steps."
      }
    },
    {
      "name": "skip_trim",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "跳过修剪步骤。",
        "en": "Skip trimming steps."
      }
    },
    {
      "name": "sra_ids",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "NCBI SRA Accession ID 列表。",
        "en": "List of NCBI SRA Accession IDs."
      }
    },
    {
      "name": "step",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "仅运行特定步骤。",
        "en": "Run only specific steps."
      }
    },
    {
      "name": "qc_params",
      "type": "dict",
      "required": false,
      "default": null,
      "description": {
        "zh": "额外的 QC 参数。",
        "en": "Additional QC parameters."
      }
    },
    {
      "name": "star_align",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "启用 STAR 比对。",
        "en": "Enable STAR alignment."
      }
    },
    {
      "name": "theme",
      "type": "string",
      "required": false,
      "default": "default",
      "description": {
        "zh": "绘图主题。",
        "en": "Plotting theme."
      }
    }
  ]
}
