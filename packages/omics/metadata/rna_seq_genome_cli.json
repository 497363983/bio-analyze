{
  "name": "rna_seq_genome",
  "type": "cli",
  "description": {
    "zh": "Prepare reference genome (download or index).",
    "en": "Prepare reference genome (download or index)."
  },
  "params": [
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Output directory.",
        "en": "Output directory."
      }
    },
    {
      "name": "-s, --species",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Species name.",
        "en": "Species name."
      }
    },
    {
      "name": "--assembly",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Reference assembly accession, e.g. GCA_013347765.1.",
        "en": "Reference assembly accession, e.g. GCA_013347765.1."
      }
    },
    {
      "name": "--fasta",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Genome FASTA file.",
        "en": "Genome FASTA file."
      }
    },
    {
      "name": "--gtf",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Genome GTF file.",
        "en": "Genome GTF file."
      }
    }
  ]
}