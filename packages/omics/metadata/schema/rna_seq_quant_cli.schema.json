{
  "name": "rna_seq_quant",
  "type": "cli",
  "description": "Run extensible transcript quantification.",
  "params": [
    {
      "field": "input_dir",
      "name": "-i, --input",
      "type": "path",
      "required": true,
      "default": null,
      "description": "Directory with clean FastQ files."
    },
    {
      "field": "output_dir",
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": "Output directory."
    },
    {
      "field": "fasta",
      "name": "--fasta",
      "type": "path",
      "required": true,
      "default": null,
      "description": "Genome/Transcriptome FASTA file."
    },
    {
      "field": "gtf",
      "name": "--gtf",
      "type": "path",
      "required": false,
      "default": null,
      "description": "Genome GTF file (optional if FASTA is transcriptome)."
    },
    {
      "field": "tool",
      "name": "--tool",
      "type": "string",
      "required": false,
      "default": "salmon",
      "description": "Quantification tool name."
    },
    {
      "field": "compare_tools",
      "name": "--compare-tool",
      "type": "string",
      "required": false,
      "default": null,
      "description": "Optional comparison quantifiers, repeatable."
    },
    {
      "field": "threads",
      "name": "-t, --threads",
      "type": "int",
      "required": false,
      "default": "4",
      "description": "Number of threads."
    }
  ]
}