{
  "name": "rna_seq_download",
  "type": "cli",
  "description": {
    "zh": "Download FastQ files from SRA.",
    "en": "Download FastQ files from SRA."
  },
  "params": [
    {
      "name": "--sra-ids",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "List of SRA Accession IDs.",
        "en": "List of SRA Accession IDs."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Output directory.",
        "en": "Output directory."
      }
    },
    {
      "name": "-t, --threads",
      "type": "int",
      "required": false,
      "default": "4",
      "description": {
        "zh": "Number of threads.",
        "en": "Number of threads."
      }
    }
  ]
}