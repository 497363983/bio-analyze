#: src/bio_analyze_omics/rna_seq/commands/qc.py:26
msgid "Adapter sequence R1."
msgstr "R1 接头序列。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:27
msgid "Adapter sequence R2."
msgstr "R2 接头序列。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:167
msgid "Adapter sequence for read1. Auto-detected if not provided."
msgstr "read1 的接头序列。未提供时自动检测。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:171
msgid "Adapter sequence for read2. Auto-detected if not provided."
msgstr "read2 的接头序列。未提供时自动检测。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:87
msgid ""
"CSV file describing experimental design (columns: sample, condition, ...)."
msgstr "描述实验设计的 CSV 文件（列如 sample、condition 等）。"

#: src/bio_analyze_omics/cli.py:14
msgid "Collection of omics analysis workflows."
msgstr "多组学分析工作流集合。"

#: src/bio_analyze_omics/rna_seq/commands/gsea.py:26
msgid "Column for ranking (auto, stat, log2FoldChange)."
msgstr "用于排序的列（auto、stat、log2FoldChange）。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:134
msgid "Comparison quantifiers, repeatable."
msgstr "对比定量工具，可重复指定。"

#: src/bio_analyze_omics/rna_seq/commands/de.py:13
msgid "Counts matrix CSV file."
msgstr "计数矩阵 CSV 文件。"

#: src/bio_analyze_omics/rna_seq/commands/enrich.py:14
#: src/bio_analyze_omics/rna_seq/commands/gsea.py:14
msgid "DESeq2 results CSV file."
msgstr "DESeq2 结果 CSV 文件。"

#: src/bio_analyze_omics/rna_seq/commands/de.py:14
msgid "Design matrix CSV file."
msgstr "设计矩阵 CSV 文件。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:73
msgid ""
"Directory containing raw FastQ files. Required if --sra-ids is not provided."
msgstr "包含原始 FastQ 文件的目录。未提供 --sra-ids 时必填。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:81
msgid "Directory for analysis results."
msgstr "分析结果目录。"

#: src/bio_analyze_omics/rna_seq/commands/align.py:14
#: src/bio_analyze_omics/rna_seq/commands/quant.py:14
msgid "Directory with clean FastQ files."
msgstr "包含清洗后 FastQ 文件的目录。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:117
msgid "Enable STAR alignment and chromosome distribution analysis."
msgstr "启用 STAR 比对和染色体分布分析。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:180
msgid "Enable cut_right (sliding window trimming)."
msgstr "启用 cut_right（滑动窗口剪切）。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:28
#: src/bio_analyze_omics/rna_seq/commands/run.py:189
msgid "Enable deduplication."
msgstr "启用去重。"

#: src/bio_analyze_omics/rna_seq/commands/gsea.py:22
msgid "Gene sets library (e.g. KEGG_2021_Human, GO_Biological_Process_2021)."
msgstr "基因集库（例如 KEGG_2021_Human、GO_Biological_Process_2021）。"

#: src/bio_analyze_omics/rna_seq/commands/align.py:17
#: src/bio_analyze_omics/rna_seq/commands/genome.py:20
msgid "Genome FASTA file."
msgstr "基因组 FASTA 文件。"

#: src/bio_analyze_omics/rna_seq/commands/quant.py:23
msgid "Genome GTF file (optional if FASTA is transcriptome)."
msgstr "基因组 GTF 文件（若 FASTA 为转录组则可选）。"

#: src/bio_analyze_omics/rna_seq/commands/align.py:18
#: src/bio_analyze_omics/rna_seq/commands/genome.py:21
msgid "Genome GTF file."
msgstr "基因组 GTF 文件。"

#: src/bio_analyze_omics/rna_seq/commands/quant.py:18
msgid "Genome/Transcriptome FASTA file."
msgstr "基因组/转录组 FASTA 文件。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:151
msgid "How many N bases are allowed. Default 5."
msgstr "允许的 N 碱基数量。默认 5。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:148
msgid ""
"How many percents of bases are allowed to be unqualified (0~100). Default 40"
" means 40%."
msgstr "允许不合格碱基所占百分比（0~100）。默认 40 表示 40%。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:159
msgid ""
"If read1 is longer than max_len1, trim it at tail. Default 0 (no trim)."
msgstr "如果 read1 长于 max_len1，则从末端截断。默认 0（不截断）。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:163
msgid ""
"If read2 is longer than max_len2, trim it at tail. Default 0 (no trim)."
msgstr "如果 read2 长于 max_len2，则从末端截断。默认 0（不截断）。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:13
msgid "Input directory (raw FastQ)."
msgstr "输入目录（原始 FastQ）。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:25
msgid "Length required."
msgstr "最小保留长度。"

#: src/bio_analyze_omics/rna_seq/commands/download.py:12
msgid "List of SRA Accession IDs."
msgstr "SRA accession ID 列表。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:187
msgid "Mean quality requirement for cut_right. Default 20."
msgstr "cut_right 的平均质量要求。默认 20。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:192
msgid "Minimum length for polyG tail trimming. Default 10."
msgstr "polyG 尾剪切的最小长度。默认 10。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:24
msgid "N base limit."
msgstr "N 碱基数量上限。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:110
msgid "Number of threads to use."
msgstr "使用的线程数。"

#: src/bio_analyze_omics/rna_seq/commands/align.py:19
#: src/bio_analyze_omics/rna_seq/commands/download.py:14
#: src/bio_analyze_omics/rna_seq/commands/qc.py:16
#: src/bio_analyze_omics/rna_seq/commands/quant.py:37
msgid "Number of threads."
msgstr "线程数。"

#: src/bio_analyze_omics/rna_seq/commands/gsea.py:28
msgid "Number of top pathways to plot."
msgstr "要绘制的顶部通路数量。"

#: src/bio_analyze_omics/rna_seq/commands/quant.py:35
msgid "Optional comparison quantifiers, repeatable."
msgstr "可选的对比定量工具，可重复指定。"

#: src/bio_analyze_omics/rna_seq/commands/align.py:16
#: src/bio_analyze_omics/rna_seq/commands/de.py:15
#: src/bio_analyze_omics/rna_seq/commands/download.py:13
#: src/bio_analyze_omics/rna_seq/commands/enrich.py:19
#: src/bio_analyze_omics/rna_seq/commands/genome.py:13
#: src/bio_analyze_omics/rna_seq/commands/gsea.py:19
#: src/bio_analyze_omics/rna_seq/commands/qc.py:15
#: src/bio_analyze_omics/rna_seq/commands/quant.py:16
msgid "Output directory."
msgstr "输出目录。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:67
msgid "Path to JSON/YAML config file. Overrides other options if provided."
msgstr "JSON/YAML 配置文件路径。提供后会覆盖其他选项。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:103
msgid ""
"Path to reference genome FASTA file (overrides --species/--assembly auto-"
"download)."
msgstr "参考基因组 FASTA 文件路径（覆盖 --species/--assembly 自动下载）。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:108
msgid ""
"Path to reference genome GTF annotation file (overrides --species/--assembly"
" auto-download)."
msgstr "参考基因组 GTF 注释文件路径（覆盖 --species/--assembly 自动下载）。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:20
msgid "Phred quality threshold."
msgstr "Phred 质量阈值。"

#: src/bio_analyze_omics/rna_seq/commands/align.py:20
#: src/bio_analyze_omics/rna_seq/commands/de.py:16
#: src/bio_analyze_omics/rna_seq/commands/enrich.py:20
#: src/bio_analyze_omics/rna_seq/commands/gsea.py:29
msgid "Plot theme."
msgstr "绘图主题。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:122
msgid "Plotting theme (default, nature, science, or custom package name)."
msgstr "绘图主题（default、nature、science 或自定义包名）。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:155
msgid "Reads shorter than length_required will be discarded. Default 15."
msgstr "长度短于 length_required 的 reads 将被丢弃。默认 15。"

#: src/bio_analyze_omics/rna_seq/commands/genome.py:18
msgid "Reference assembly accession, e.g. GCA_013347765.1."
msgstr "参考组装 accession，例如 GCA_013347765.1。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:98
msgid ""
"Reference assembly accession, e.g. GCA_013347765.1. Takes precedence over "
"--species for auto-download."
msgstr "参考组装 accession，例如 GCA_013347765.1。自动下载时优先于 --species。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:139
msgid ""
"Run only a specific step (qc, quant, de, enrichment, report). If None, run "
"all."
msgstr "仅运行指定步骤（qc、quant、de、enrichment、report）。为 None 时运行全部。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:78
msgid "SRA Accession IDs to download and process (e.g. SRR123456)."
msgstr "要下载并处理的 SRA accession ID（例如 SRR123456）。"

#: src/bio_analyze_omics/rna_seq/commands/utils.py:85
msgid "Select the reference genome number to download"
msgstr "选择要下载的参考基因组编号"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:17
msgid "Skip FastQC/fastp stats."
msgstr "跳过 FastQC/fastp 统计。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:111
msgid "Skip Quality Control step."
msgstr "跳过质量控制步骤。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:112
msgid "Skip Trimming step."
msgstr "跳过剪切步骤。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:18
msgid "Skip trimming."
msgstr "跳过剪切。"

#: src/bio_analyze_omics/rna_seq/commands/enrich.py:17
#: src/bio_analyze_omics/rna_seq/commands/gsea.py:17
msgid "Species name (e.g. 'Homo sapiens')."
msgstr "物种名称（例如 'Homo sapiens'）。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:93
msgid ""
"Species name for auto-downloading reference genome (e.g. 'Homo sapiens')."
msgstr "用于自动下载参考基因组的物种名称（例如 'Homo sapiens'）。"

#: src/bio_analyze_omics/rna_seq/commands/genome.py:14
msgid "Species name."
msgstr "物种名称。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:144
msgid ""
"The quality value that a base is qualified. Default 15 means Phred quality "
">= Q15."
msgstr "判定碱基为合格的质量值。默认 15 表示 Phred 质量 >= Q15。"

#: src/bio_analyze_omics/rna_seq/cli.py:21
msgid "Transcriptomics analysis workflow."
msgstr "转录组分析工作流。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:174
msgid "Trimming how many bases in front for read1."
msgstr "对 read1 前端剪切的碱基数。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:177
msgid "Trimming how many bases in tail for read1."
msgstr "对 read1 末端剪切的碱基数。"

#: src/bio_analyze_omics/rna_seq/commands/qc.py:22
msgid "Unqualified percent limit."
msgstr "不合格碱基百分比上限。"

#: src/bio_analyze_omics/rna_seq/commands/run.py:183
msgid "Window size for cut_right. Default 4."
msgstr "cut_right 的窗口大小。默认 4。"
