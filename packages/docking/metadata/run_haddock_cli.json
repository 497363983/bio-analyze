{
  "name": "run_haddock",
  "type": "cli",
  "description": {
    "zh": "Run molecular docking using HADDOCK engine.",
    "en": "Run molecular docking using HADDOCK engine."
  },
  "params": [
    {
      "name": "--config, -c",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Config file path.",
        "en": "Config file path."
      }
    },
    {
      "name": "-r, --receptor",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Receptor file/dir.",
        "en": "Receptor file/dir."
      }
    },
    {
      "name": "-l, --ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Ligand file/dir.",
        "en": "Ligand file/dir."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Output dir.",
        "en": "Output dir."
      }
    },
    {
      "name": "--n-poses",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "Number of poses to sample.",
        "en": "Number of poses to sample."
      }
    },
    {
      "name": "--charge-model",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Charge model.",
        "en": "Charge model."
      }
    },
    {
      "name": "--haddock-config",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Custom HADDOCK3 configuration file path.",
        "en": "Custom HADDOCK3 configuration file path."
      }
    }
  ]
}