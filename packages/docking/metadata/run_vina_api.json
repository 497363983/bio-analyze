{
  "name": "run_vina",
  "type": "api",
  "description": {
    "zh": "Run complete docking pipeline for a single receptor-ligand pair using Vina engine.",
    "en": "Run complete docking pipeline for a single receptor-ligand pair using Vina engine."
  },
  "params": [
    {
      "name": "receptor",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Path to receptor file (PDB/PDBQT).",
        "en": "Path to receptor file (PDB/PDBQT)."
      }
    },
    {
      "name": "ligand",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Path to ligand file (SDF/MOL2/PDB/SMILES).",
        "en": "Path to ligand file (SDF/MOL2/PDB/SMILES)."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Output directory.",
        "en": "Output directory."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Center of search space [x, y, z]. If None, automatically calculated.",
        "en": "Center of search space [x, y, z]. If None, automatically calculated."
      }
    },
    {
      "name": "size",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Size of search space [x, y, z] in Angstroms.",
        "en": "Size of search space [x, y, z] in Angstroms."
      }
    },
    {
      "name": "autobox_ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Reference ligand for automatically calculating search box.",
        "en": "Reference ligand for automatically calculating search box."
      }
    },
    {
      "name": "padding",
      "type": "float",
      "required": false,
      "default": "4.0",
      "description": {
        "zh": "Padding added to auto-calculated box (Angstroms).",
        "en": "Padding added to auto-calculated box (Angstroms)."
      }
    },
    {
      "name": "exhaustiveness",
      "type": "int",
      "required": false,
      "default": "8",
      "description": {
        "zh": "Exhaustiveness of the global search.",
        "en": "Exhaustiveness of the global search."
      }
    },
    {
      "name": "n_poses",
      "type": "int",
      "required": false,
      "default": "9",
      "description": {
        "zh": "Maximum number of poses to output.",
        "en": "Maximum number of poses to output."
      }
    },
    {
      "name": "summary_filename",
      "type": "string",
      "required": false,
      "default": "docking_summary.csv",
      "description": {
        "zh": "Summary results filename.",
        "en": "Summary results filename."
      }
    },
    {
      "name": "output_docked_lig_recep_struct",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to output docked receptor-ligand complex structure.",
        "en": "Whether to output docked receptor-ligand complex structure."
      }
    },
    {
      "name": "n_docked_lig_recep_struct",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "Number of complex structures to output.",
        "en": "Number of complex structures to output."
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "Charge model for receptor preparation.",
        "en": "Charge model for receptor preparation."
      }
    }
  ]
}