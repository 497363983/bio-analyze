{
  "name": "prepare_receptor",
  "type": "api",
  "description": {
    "zh": "准备受体用于对接 (PDB -> PDBQT)。\n使用 PDBFixer 修复结构，PropKa 进行 pKa 分析，\n并使用 Meeko 转换为 PDBQT 格式。",
    "en": "准备受体用于对接 (PDB -> PDBQT)。\n使用 PDBFixer 修复结构，PropKa 进行 pKa 分析，\n并使用 Meeko 转换为 PDBQT 格式。"
  },
  "params": [
    {
      "name": "input_file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入 PDB 文件路径",
        "en": "输入 PDB 文件路径"
      }
    },
    {
      "name": "output_file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出 PDBQT 文件路径",
        "en": "输出 PDBQT 文件路径"
      }
    },
    {
      "name": "add_hydrogens",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否加氢",
        "en": "是否加氢"
      }
    },
    {
      "name": "ph",
      "type": "float",
      "required": false,
      "default": "7.4",
      "description": {
        "zh": "质子化状态计算的 pH 值",
        "en": "质子化状态计算的 pH 值"
      }
    },
    {
      "name": "keep_water",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否保留结晶水",
        "en": "是否保留结晶水"
      }
    },
    {
      "name": "rigid_macrocycles",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否将大环视为刚性",
        "en": "是否将大环视为刚性"
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "Meeko 的电荷模型 (例如 'gasteiger', 'zero', 'scikit_learn')。",
        "en": "Meeko 的电荷模型 (例如 'gasteiger', 'zero', 'scikit_learn')。"
      }
    }
  ]
}