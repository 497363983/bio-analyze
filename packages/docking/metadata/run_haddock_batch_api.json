{
  "name": "run_haddock_batch",
  "type": "api",
  "description": {
    "zh": "Run batch docking pipeline using HADDOCK engine.",
    "en": "Run batch docking pipeline using HADDOCK engine."
  },
  "params": [
    {
      "name": "receptors",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Receptors directory or file.",
        "en": "Receptors directory or file."
      }
    },
    {
      "name": "ligands",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Ligands directory or file.",
        "en": "Ligands directory or file."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Output directory.",
        "en": "Output directory."
      }
    },
    {
      "name": "n_poses",
      "type": "int",
      "required": false,
      "default": "10",
      "description": {
        "zh": "Number of poses to sample.",
        "en": "Number of poses to sample."
      }
    },
    {
      "name": "summary_filename",
      "type": "string",
      "required": false,
      "default": "docking_summary.csv",
      "description": {
        "zh": "Summary results filename.",
        "en": "Summary results filename."
      }
    },
    {
      "name": "output_docked_lig_recep_struct",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to output docked receptor-ligand complex structure.",
        "en": "Whether to output docked receptor-ligand complex structure."
      }
    },
    {
      "name": "n_docked_lig_recep_struct",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "Number of complex structures to output.",
        "en": "Number of complex structures to output."
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "Charge model for receptor preparation.",
        "en": "Charge model for receptor preparation."
      }
    },
    {
      "name": "haddock_config",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to custom HADDOCK3 configuration file.",
        "en": "Path to custom HADDOCK3 configuration file."
      }
    }
  ]
}