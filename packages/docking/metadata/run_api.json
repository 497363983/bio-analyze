{
  "name": "run",
  "type": "api",
  "description": {
    "zh": "运行单个受体-配体对的完整对接流程。",
    "en": "Run complete docking pipeline for a single receptor-ligand pair."
  },
  "params": [
    {
      "name": "receptor",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "受体文件路径 (PDB/PDBQT)。",
        "en": "Path to receptor file (PDB/PDBQT)."
      }
    },
    {
      "name": "ligand",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "配体文件路径 (SDF/MOL2/PDB/SMILES)。",
        "en": "Path to ligand file (SDF/MOL2/PDB/SMILES)."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出目录。",
        "en": "Output directory."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "盒子中心 [x, y, z]。",
        "en": "Box center [x, y, z]."
      }
    },
    {
      "name": "size",
      "type": "float",
      "required": false,
      "default": "[20.0, 20.0, 20.0]",
      "description": {
        "zh": "盒子大小 [x, y, z]。",
        "en": "Box size [x, y, z]."
      }
    },
    {
      "name": "autobox_ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "用于自动盒计算的配体路径。",
        "en": "Ligand path for autobox calculation."
      }
    },
    {
      "name": "padding",
      "type": "float",
      "required": false,
      "default": "4.0",
      "description": {
        "zh": "自动盒填充。",
        "en": "Autobox padding."
      }
    },
    {
      "name": "exhaustiveness",
      "type": "int",
      "required": false,
      "default": "8",
      "description": {
        "zh": "Vina 穷尽性。",
        "en": "Vina exhaustiveness."
      }
    },
    {
      "name": "n_poses",
      "type": "int",
      "required": false,
      "default": "9",
      "description": {
        "zh": "姿态数量。",
        "en": "Number of poses."
      }
    },
    {
      "name": "summary_filename",
      "type": "string",
      "required": false,
      "default": "docking_summary.csv",
      "description": {
        "zh": "摘要文件名。",
        "en": "Summary filename."
      }
    },
    {
      "name": "output_docked_lig_recep_struct",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否保存复合物结构（PDB 格式，通过 PyMOL）。",
        "en": "Whether to save complex structure (PDB format, via PyMOL)."
      }
    },
    {
      "name": "n_docked_lig_recep_struct",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "要保存的复合物数量。",
        "en": "Number of complexes to save."
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "受体准备的电荷模型 (例如 'gasteiger', 'zero')。",
        "en": "Charge model for receptor preparation (e.g. 'gasteiger', 'zero')."
      }
    },
    {
      "name": "engine",
      "type": "string",
      "required": false,
      "default": "vina",
      "description": {
        "zh": "对接引擎类型 (例如 'vina', 'gnina')。",
        "en": "Docking engine type (e.g. 'vina', 'gnina')."
      }
    }
  ]
}
