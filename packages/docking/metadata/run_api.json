{
  "name": "run",
  "type": "api",
  "description": {
    "zh": "Run complete docking pipeline for a single receptor-ligand pair.",
    "en": "Run complete docking pipeline for a single receptor-ligand pair."
  },
  "params": [
    {
      "name": "receptor",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Path to receptor file (PDB/PDBQT).",
        "en": "Path to receptor file (PDB/PDBQT)."
      }
    },
    {
      "name": "ligand",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Path to ligand file (SDF/MOL2/PDB/SMILES).",
        "en": "Path to ligand file (SDF/MOL2/PDB/SMILES)."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Output directory.",
        "en": "Output directory."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Box center [x, y, z].",
        "en": "Box center [x, y, z]."
      }
    },
    {
      "name": "size",
      "type": "float",
      "required": false,
      "default": "[20.0, 20.0, 20.0]",
      "description": {
        "zh": "Box size [x, y, z].",
        "en": "Box size [x, y, z]."
      }
    },
    {
      "name": "autobox_ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Ligand path for autobox calculation.",
        "en": "Ligand path for autobox calculation."
      }
    },
    {
      "name": "padding",
      "type": "float",
      "required": false,
      "default": "4.0",
      "description": {
        "zh": "Autobox padding.",
        "en": "Autobox padding."
      }
    },
    {
      "name": "exhaustiveness",
      "type": "int",
      "required": false,
      "default": "8",
      "description": {
        "zh": "Vina exhaustiveness.",
        "en": "Vina exhaustiveness."
      }
    },
    {
      "name": "n_poses",
      "type": "int",
      "required": false,
      "default": "9",
      "description": {
        "zh": "Number of poses.",
        "en": "Number of poses."
      }
    },
    {
      "name": "summary_filename",
      "type": "string",
      "required": false,
      "default": "docking_summary.csv",
      "description": {
        "zh": "Summary filename.",
        "en": "Summary filename."
      }
    },
    {
      "name": "output_docked_lig_recep_struct",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to save complex structure (PDB format, via PyMOL).",
        "en": "Whether to save complex structure (PDB format, via PyMOL)."
      }
    },
    {
      "name": "n_docked_lig_recep_struct",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "Number of complexes to save.",
        "en": "Number of complexes to save."
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "Charge model for receptor preparation (e.g. 'gasteiger', 'zero').",
        "en": "Charge model for receptor preparation (e.g. 'gasteiger', 'zero')."
      }
    },
    {
      "name": "engine",
      "type": "Literal['vina', 'smina', 'gnina', 'haddock']",
      "required": false,
      "default": "vina",
      "description": {
        "zh": "Docking engine type (e.g. 'vina', 'gnina', 'haddock').",
        "en": "Docking engine type (e.g. 'vina', 'gnina', 'haddock')."
      }
    },
    {
      "name": "haddock_config",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "",
        "en": ""
      }
    }
  ]
}