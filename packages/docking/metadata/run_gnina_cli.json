    {
      "name": "--n-poses",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "Number of poses.",
        "en": "Number of poses."
      }
    },
    {
      "name": "--charge-model",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Charge model.",
        "en": "Charge model."
      }
    }
