{
  "name": "run_gnina",
  "type": "cli",
  "description": {
    "zh": "Run molecular docking using Gnina engine.",
    "en": "Run molecular docking using Gnina engine."
  },
  "params": [
    {
      "name": "--config, -c",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Config file path.",
        "en": "Config file path."
      }
    },
    {
      "name": "-r, --receptor",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Receptor file/dir.",
        "en": "Receptor file/dir."
      }
    },
    {
      "name": "-l, --ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Ligand file/dir.",
        "en": "Ligand file/dir."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Output dir.",
        "en": "Output dir."
