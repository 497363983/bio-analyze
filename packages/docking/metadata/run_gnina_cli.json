      "name": "--size-x",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Box size X.",
        "en": "Box size X."
      }
    },
    {
      "name": "--size-y",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Box size Y.",
        "en": "Box size Y."
      }
