{
  "name": "run_batch",
  "type": "api",
  "description": {
    "zh": "Run docking for multiple receptors and/or ligands (M x N).",
    "en": "Run docking for multiple receptors and/or ligands (M x N)."
  },
  "params": [
    {
      "name": "receptors",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "List of receptor paths or directory containing receptors.",
        "en": "List of receptor paths or directory containing receptors."
      }
    },
    {
      "name": "ligands",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "List of ligand paths or directory containing ligands.",
        "en": "List of ligand paths or directory containing ligands."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "Base output directory.",
        "en": "Base output directory."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Box center [x, y, z].",
        "en": "Box center [x, y, z]."
      }
    },
    {
      "name": "size",
      "type": "float",
      "required": false,
      "default": "[20.0, 20.0, 20.0]",
      "description": {
        "zh": "Box size [x, y, z].",
        "en": "Box size [x, y, z]."
      }
    },
    {
      "name": "autobox_ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "Ligand path for autobox calculation.",
        "en": "Ligand path for autobox calculation."
      }
    },
    {
      "name": "padding",
      "type": "float",
      "required": false,
      "default": "4.0",
      "description": {
        "zh": "Autobox padding.",
        "en": "Autobox padding."
      }
    },
    {
      "name": "exhaustiveness",
      "type": "int",
      "required": false,
      "default": "8",
      "description": {
        "zh": "Vina exhaustiveness.",
        "en": "Vina exhaustiveness."
      }
    },
    {
      "name": "n_poses",
      "type": "int",
      "required": false,
      "default": "9",
      "description": {
        "zh": "Number of poses.",
        "en": "Number of poses."
      }
    },
    {
      "name": "summary_filename",
      "type": "string",
      "required": false,
      "default": "docking_summary.csv",
      "description": {
        "zh": "Summary filename.",
        "en": "Summary filename."
      }
    },
    {
      "name": "output_docked_lig_recep_struct",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to save complex structure (PDB format, via PyMOL).",
        "en": "Whether to save complex structure (PDB format, via PyMOL)."
      }
    },
    {
      "name": "n_docked_lig_recep_struct",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "Number of complexes to save.",
        "en": "Number of complexes to save."
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "Charge model for receptor preparation (e.g. 'gasteiger', 'zero').",
        "en": "Charge model for receptor preparation (e.g. 'gasteiger', 'zero')."
      }
    },
    {
      "name": "engine",
      "type": "Literal['vina', 'smina', 'gnina', 'haddock']",
      "required": false,
      "default": "vina",
      "description": {
        "zh": "Docking engine type (e.g. 'vina', 'gnina', 'haddock').",
        "en": "Docking engine type (e.g. 'vina', 'gnina', 'haddock')."
      }
    },
    {
      "name": "boxes",
      "type": "dict",
      "required": false,
      "default": null,
      "description": {
        "zh": "Dictionary of box configurations for specific receptors.",
        "en": "Dictionary of box configurations for specific receptors."
      }
    },
    {
      "name": "haddock_config",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "",
        "en": ""
      }
    }
  ]
}