{
  "name": "run_batch",
  "type": "api",
  "description": {
    "zh": "对多个受体和/或配体 (M x N) 运行对接。",
    "en": "Run docking for multiple receptors and/or ligands (M x N)."
  },
  "params": [
    {
      "name": "receptors",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "受体路径列表或包含受体的目录。",
        "en": "List of receptor paths or directory containing receptors."
      }
    },
    {
      "name": "ligands",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "配体路径列表或包含配体的目录。",
        "en": "List of ligand paths or directory containing ligands."
      }
    },
    {
      "name": "output_dir",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "基础输出目录。",
        "en": "Base output directory."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "盒子中心 [x, y, z]。",
        "en": "Box center [x, y, z]."
      }
    },
    {
      "name": "size",
      "type": "float",
      "required": false,
      "default": "[20.0, 20.0, 20.0]",
      "description": {
        "zh": "盒子大小 [x, y, z]。",
        "en": "Box size [x, y, z]."
      }
    },
    {
      "name": "autobox_ligand",
      "type": "path",
      "required": false,
      "default": null,
      "description": {
        "zh": "用于自动盒计算的配体路径。",
        "en": "Ligand path for autobox calculation."
      }
    },
    {
      "name": "padding",
      "type": "float",
      "required": false,
      "default": "4.0",
      "description": {
        "zh": "自动盒填充。",
        "en": "Autobox padding."
      }
    },
    {
      "name": "exhaustiveness",
      "type": "int",
      "required": false,
      "default": "8",
      "description": {
        "zh": "Vina 穷尽性。",
        "en": "Vina exhaustiveness."
      }
    },
    {
      "name": "n_poses",
      "type": "int",
      "required": false,
      "default": "9",
      "description": {
        "zh": "姿态数量。",
        "en": "Number of poses."
      }
    },
    {
      "name": "summary_filename",
      "type": "string",
      "required": false,
      "default": "docking_summary.csv",
      "description": {
        "zh": "摘要文件名（例如 'summary.csv', 'results.xlsx'）或 None 以禁用。",
        "en": "Summary filename (e.g. 'summary.csv', 'results.xlsx') or None to disable."
      }
    },
    {
      "name": "output_docked_lig_recep_struct",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否输出对接的复合物结构（PDB 格式，通过 PyMOL）。",
        "en": "Whether to output docked complex structures (PDB format, via PyMOL)."
      }
    },
    {
      "name": "n_docked_lig_recep_struct",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "要保存的前几名复合物数量（None=全部）。",
        "en": "Number of top complexes to save (None=All)."
      }
    },
    {
      "name": "charge_model",
      "type": "string",
      "required": false,
      "default": "gasteiger",
      "description": {
        "zh": "受体准备的电荷模型 (例如 'gasteiger', 'zero')。",
        "en": "Charge model for receptor preparation (e.g. 'gasteiger', 'zero')."
      }
    },
    {
      "name": "engine",
      "type": "string",
      "required": false,
      "default": "vina",
      "description": {
        "zh": "对接引擎类型 (例如 'vina', 'gnina')。",
        "en": "Docking engine type (e.g. 'vina', 'gnina')."
      }
    }
  ]
}