{
  "name": "gsea",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--rank",
      "type": "string",
      "required": false,
      "default": "rank",
      "description": {
        "zh": "排名列名 (X 轴)。",
        "en": "Column name for rank (x-axis)."
      }
    },
    {
      "name": "--score",
      "type": "string",
      "required": false,
      "default": "running_es",
      "description": {
        "zh": "运行富集得分列名 (Y 轴)。",
        "en": "Column name for running ES (y-axis)."
      }
    },
    {
      "name": "--hit",
      "type": "string",
      "required": false,
      "default": "hit",
      "description": {
        "zh": "命中状态列名 (0/1 或布尔值)。",
        "en": "Column name for hit status (0/1 or boolean)."
      }
    },
    {
      "name": "--metric",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "排名指标列名 (Y 轴底部)。",
        "en": "Column name for ranking metric (y-axis bottom)."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    },
    {
      "name": "--color",
      "type": "string",
      "required": false,
      "default": "#4DAF4A",
      "description": {
        "zh": "富集得分曲线颜色。",
        "en": "Color for enrichment score line."
      }
    },
    {
      "name": "--hit-color",
      "type": "string",
      "required": false,
      "default": "black",
      "description": {
        "zh": "命中线条颜色。",
        "en": "Color for hit lines."
      }
    },
    {
      "name": "--nes",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "标准化富集得分 (NES)。",
        "en": "Normalized Enrichment Score."
      }
    },
    {
      "name": "--pvalue",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "P-value。",
        "en": "P-value."
      }
    },
    {
      "name": "--fdr",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "FDR q-value。",
        "en": "FDR q-value."
      }
    },
    {
      "name": "--show-border",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "显示顶部和右侧边框。",
        "en": "Show top and right borders."
      }
    }
  ]
}
