{
  "name": "chromosome",
  "type": "api",
  "description": {
    "zh": "绘制 Reads 在染色体上的覆盖度分布图（区分正负链）。",
    "en": "Plot Reads coverage distribution on chromosomes (differentiating strands)."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含 bin 统计数据的 DataFrame。必需列: chrom, pos (bin start), counts_pos, counts_neg。",
        "en": "DataFrame containing bin statistics. Required columns: chrom, pos (bin start), counts_pos, counts_neg."
      }
    },
    {
      "name": "chrom_col",
      "type": "string",
      "required": false,
      "default": "chrom",
      "description": {
        "zh": "染色体列名。",
        "en": "Column name for chromosome."
      }
    },
    {
      "name": "pos_col",
      "type": "string",
      "required": false,
      "default": "pos",
      "description": {
        "zh": "位置列名（bin 起始位）。",
        "en": "Column name for position (bin start)."
      }
    },
    {
      "name": "pos_counts_col",
      "type": "string",
      "required": false,
      "default": "counts_pos",
      "description": {
        "zh": "正链 Reads 计数列名。",
        "en": "Column name for positive strand reads count."
      }
    },
    {
      "name": "neg_counts_col",
      "type": "string",
      "required": false,
      "default": "counts_neg",
      "description": {
        "zh": "负链 Reads 计数列名。",
        "en": "Column name for negative strand reads count."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": "Reads Coverage Distribution on Chromosomes",
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存路径。",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "max_chroms",
      "type": "int",
      "required": false,
      "default": "30",
      "description": {
        "zh": "最多显示的染色体数量（按长度或名称排序后）。",
        "en": "Maximum number of chromosomes to display (after sorting by length or name)."
      }
    },
    {
      "name": "bin_size",
      "type": "int",
      "required": false,
      "default": "100000",
      "description": {
        "zh": "Bin 大小（用于 X 轴单位换算或标注）。",
        "en": "Bin size (used for X-axis unit conversion or annotation)."
      }
    },
    {
      "name": "color_pos",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "正链颜色。",
        "en": "Color for positive strand."
      }
    },
    {
      "name": "color_neg",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "负链颜色。",
        "en": "Color for negative strand."
      }
    }
  ]
}
