{
  "name": "box",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "X 轴列名。",
        "en": "Column name for X-axis."
      }
    },
    {
      "name": "--y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Y 轴列名。",
        "en": "Column name for Y-axis."
      }
    },
    {
      "name": "--hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名 (hue)。",
        "en": "Grouping column name (hue)."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "显著性检验配对 (例如 'A,B' 'C,D')。",
        "en": "Pairs for significance testing (e.g. 'A,B' 'C,D')."
      }
    },
    {
      "name": "--test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "统计检验方法。",
        "en": "Statistical test method."
      }
    },
    {
      "name": "--text-format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "显著性标注格式。",
        "en": "Significance annotation format."
      }
    },
    {
      "name": "--add-swarm",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "叠加蜂群图点。",
        "en": "Overlay swarmplot points."
      }
    },
    {
      "name": "--swarm-color",
      "type": "string",
      "required": false,
      "default": ".25",
      "description": {
        "zh": "蜂群图点颜色。",
        "en": "Swarmplot point color."
      }
    },
    {
      "name": "--swarm-size",
      "type": "float",
      "required": false,
      "default": "3.0",
      "description": {
        "zh": "蜂群图点大小。",
        "en": "Swarmplot point size."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    }
  ]
}