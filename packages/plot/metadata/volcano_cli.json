{
  "name": "volcano",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径 (例如 volcano.png)。",
        "en": "Output file path (e.g. volcano.png)."
      }
    },
    {
      "name": "--x",
      "type": "string",
      "required": false,
      "default": "log2FoldChange",
      "description": {
        "zh": "log2 fold change 列名。",
        "en": "Column name for log2 fold change."
      }
    },
    {
      "name": "--y",
      "type": "string",
      "required": false,
      "default": "pvalue",
      "description": {
        "zh": "p-value 列名。",
        "en": "Column name for p-value."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--fc-cutoff",
      "type": "float",
      "required": false,
      "default": "1.0",
      "description": {
        "zh": "Fold change 截断值。",
        "en": "Fold change cutoff."
      }
    },
    {
      "name": "--p-cutoff",
      "type": "float",
      "required": false,
      "default": "0.05",
      "description": {
        "zh": "P-value 截断值。",
        "en": "P-value cutoff."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    }
  ]
}