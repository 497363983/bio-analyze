{
  "name": "heatmap",
  "type": "api",
  "description": {
    "zh": "绘制带有可选聚类的热图。",
    "en": "Plot heatmap with optional clustering."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "index_col",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "用作索引（标签）的列。如果为 None，则使用现有索引。",
        "en": "Column to use as index (labels). If None, uses existing index."
      }
    },
    {
      "name": "cluster_rows",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否对行进行聚类。",
        "en": "Whether to cluster rows."
      }
    },
    {
      "name": "cluster_cols",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否对列进行聚类。",
        "en": "Whether to cluster columns."
      }
    },
    {
      "name": "z_score",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "0（行）或 1（列）进行标准化。None 表示禁用。",
        "en": "0 (rows) or 1 (columns) for standardization. None to disable."
      }
    },
    {
      "name": "cmap",
      "type": "string",
      "required": false,
      "default": "vlag",
      "description": {
        "zh": "颜色映射名称。",
        "en": "Colormap name."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": "0.0",
      "description": {
        "zh": "颜色映射居中的值。",
        "en": "Value at which to center the colormap."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    }
  ]
}