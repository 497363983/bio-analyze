{
  "name": "heatmap",
  "type": "api",
  "description": {
    "zh": "绘制带有可选聚类的热图。",
    "en": "绘制带有可选聚类的热图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "包含数据的 DataFrame。"
      }
    },
    {
      "name": "index_col",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "用作索引（标签）的列。如果为 None，则使用现有索引。",
        "en": "用作索引（标签）的列。如果为 None，则使用现有索引。"
      }
    },
    {
      "name": "cluster_rows",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否对行进行聚类。",
        "en": "是否对行进行聚类。"
      }
    },
    {
      "name": "cluster_cols",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否对列进行聚类。",
        "en": "是否对列进行聚类。"
      }
    },
    {
      "name": "z_score",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "0（行）或 1（列）进行标准化。None 表示禁用。",
        "en": "0（行）或 1（列）进行标准化。None 表示禁用。"
      }
    },
    {
      "name": "cmap",
      "type": "string",
      "required": false,
      "default": "vlag",
      "description": {
        "zh": "颜色映射名称。",
        "en": "颜色映射名称。"
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": "0.0",
      "description": {
        "zh": "颜色映射居中的值。",
        "en": "颜色映射居中的值。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X轴标签。"
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y轴标签。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "保存图表的路径。"
      }
    }
  ]
}