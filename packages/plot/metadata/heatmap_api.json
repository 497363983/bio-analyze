{
  "name": "heatmap",
  "type": "api",
  "description": {
    "zh": "Plot heatmap with optional clustering.",
    "en": "Plot heatmap with optional clustering."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "index_col",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column to use as index (labels). If None, uses existing index.",
        "en": "Column to use as index (labels). If None, uses existing index."
      }
    },
    {
      "name": "cluster_rows",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "Whether to cluster rows.",
        "en": "Whether to cluster rows."
      }
    },
    {
      "name": "cluster_cols",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "Whether to cluster columns.",
        "en": "Whether to cluster columns."
      }
    },
    {
      "name": "z_score",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "0 (rows) or 1 (columns) for standardization. None to disable.",
        "en": "0 (rows) or 1 (columns) for standardization. None to disable."
      }
    },
    {
      "name": "cmap",
      "type": "string",
      "required": false,
      "default": "vlag",
      "description": {
        "zh": "Colormap name.",
        "en": "Colormap name."
      }
    },
    {
      "name": "center",
      "type": "float",
      "required": false,
      "default": "0.0",
      "description": {
        "zh": "Value at which to center the colormap.",
        "en": "Value at which to center the colormap."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X-axis label.",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y-axis label.",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    }
  ]
}