{
  "name": "chromosome",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--chrom-col",
      "type": "string",
      "required": false,
      "default": "chrom",
      "description": {
        "zh": "染色体列名。",
        "en": "Column name for chromosome."
      }
    },
    {
      "name": "--pos-col",
      "type": "string",
      "required": false,
      "default": "pos",
      "description": {
        "zh": "位置列名。",
        "en": "Column name for position."
      }
    },
    {
      "name": "--pos-counts-col",
      "type": "string",
      "required": false,
      "default": "pos_counts",
      "description": {
        "zh": "正链计数列名。",
        "en": "Column name for positive strand counts."
      }
    },
    {
      "name": "--neg-counts-col",
      "type": "string",
      "required": false,
      "default": "neg_counts",
      "description": {
        "zh": "负链计数列名。",
        "en": "Column name for negative strand counts."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    },
    {
      "name": "--max-chroms",
      "type": "int",
      "required": false,
      "default": "24",
      "description": {
        "zh": "显示的最大染色体数量。",
        "en": "Maximum number of chromosomes to display."
      }
    }
  ]
}