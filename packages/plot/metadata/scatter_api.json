{
  "name": "scatter",
  "type": "api",
  "description": {
    "zh": "绘制散点图。",
    "en": "绘制散点图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "包含数据的 DataFrame。"
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "x 轴的列名。"
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "y 轴的列名。"
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "分组列名。"
      }
    },
    {
      "name": "style",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "样式列名。",
        "en": "样式列名。"
      }
    },
    {
      "name": "size",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "大小列名。",
        "en": "大小列名。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X轴标签。"
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y轴标签。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "保存图表的路径。"
      }
    },
    {
      "name": "add_ellipse",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否为每个分组绘制置信椭圆。",
        "en": "是否为每个分组绘制置信椭圆。"
      }
    },
    {
      "name": "ellipse_std",
      "type": "float",
      "required": false,
      "default": "2.0",
      "description": {
        "zh": "椭圆的标准差倍数。",
        "en": "椭圆的标准差倍数。"
      }
    }
  ]
}