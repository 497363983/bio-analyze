{
  "name": "scatter",
  "type": "api",
  "description": {
    "zh": "绘制散点图。",
    "en": "Plot scatter chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "style",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "样式分组列名。",
        "en": "Column name for style grouping."
      }
    },
    {
      "name": "size",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "大小分组列名。",
        "en": "Column name for size grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "add_ellipse",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否为每个分组绘制置信椭圆。",
        "en": "Whether to draw confidence ellipses for each group."
      }
    },
    {
      "name": "ellipse_std",
      "type": "float",
      "required": false,
      "default": "2.0",
      "description": {
        "zh": "椭圆的标准差倍数。",
        "en": "Number of standard deviations for ellipse."
      }
    }
  ]
}
