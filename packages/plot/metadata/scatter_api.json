{
  "name": "scatter",
  "type": "api",
  "description": {
    "zh": "Plot scatter chart.",
    "en": "Plot scatter chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for x-axis.",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for y-axis.",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for grouping.",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "style",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for style grouping.",
        "en": "Column name for style grouping."
      }
    },
    {
      "name": "size",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for size grouping.",
        "en": "Column name for size grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X-axis label.",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y-axis label.",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "add_ellipse",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to draw confidence ellipses for each group.",
        "en": "Whether to draw confidence ellipses for each group."
      }
    },
    {
      "name": "ellipse_std",
      "type": "float",
      "required": false,
      "default": "2.0",
      "description": {
        "zh": "Number of standard deviations for ellipse.",
        "en": "Number of standard deviations for ellipse."
      }
    }
  ]
}