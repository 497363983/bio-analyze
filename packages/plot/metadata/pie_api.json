{
  "name": "pie",
  "type": "api",
  "description": {
    "zh": "Plot pie chart.",
    "en": "Plot pie chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for labels (Categorical).",
        "en": "Column name for labels (Categorical)."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for values (Numerical).",
        "en": "Column name for values (Numerical)."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "autopct",
      "type": "string",
      "required": false,
      "default": "%1.1f%%",
      "description": {
        "zh": "Percentage format string, e.g., '%1.1f%%'.",
        "en": "Percentage format string, e.g., '%1.1f%%'."
      }
    },
    {
      "name": "startangle",
      "type": "float",
      "required": false,
      "default": "90",
      "description": {
        "zh": "Starting angle.",
        "en": "Starting angle."
      }
    },
    {
      "name": "explode",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Slices to explode. Can be column name (boolean or numeric) or list.",
        "en": "Slices to explode. Can be column name (boolean or numeric) or list."
      }
    },
    {
      "name": "shadow",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to show shadow.",
        "en": "Whether to show shadow."
      }
    },
    {
      "name": "colors",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "List of colors.",
        "en": "List of colors."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    }
  ]
}