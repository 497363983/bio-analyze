{
  "name": "pie",
  "type": "api",
  "description": {
    "zh": "绘制饼图。",
    "en": "绘制饼图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "包含数据的 DataFrame。"
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "标签列名 (Categorical)。",
        "en": "标签列名 (Categorical)。"
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "数值列名 (Numerical)。",
        "en": "数值列名 (Numerical)。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "autopct",
      "type": "string",
      "required": false,
      "default": "%1.1f%%",
      "description": {
        "zh": "百分比显示格式，例如 '%1.1f%%'。",
        "en": "百分比显示格式，例如 '%1.1f%%'。"
      }
    },
    {
      "name": "startangle",
      "type": "float",
      "required": false,
      "default": "90",
      "description": {
        "zh": "起始角度。",
        "en": "起始角度。"
      }
    },
    {
      "name": "explode",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "突出显示的切片。可以是列名（布尔值或数值），也可以是列表。",
        "en": "突出显示的切片。可以是列名（布尔值或数值），也可以是列表。"
      }
    },
    {
      "name": "shadow",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否显示阴影。",
        "en": "是否显示阴影。"
      }
    },
    {
      "name": "colors",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "颜色列表。",
        "en": "颜色列表。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "保存图表的路径。"
      }
    }
  ]
}