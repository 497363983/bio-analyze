{
  "name": "line",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "X 轴列名。",
        "en": "Column name for X-axis."
      }
    },
    {
      "name": "--y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Y 轴列名。",
        "en": "Column name for Y-axis."
      }
    },
    {
      "name": "--hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名 (hue)。",
        "en": "Grouping column name (hue)."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    },
    {
      "name": "--error-bar-type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒类型: SD, SE, CI。",
        "en": "Error bar type: SD, SE, CI."
      }
    },
    {
      "name": "--error-bar-ci",
      "type": "float",
      "required": false,
      "default": "95",
      "description": {
        "zh": "置信区间大小 (默认: 95)。",
        "en": "Confidence interval size (default: 95)."
      }
    },
    {
      "name": "--error-bar-capsize",
      "type": "float",
      "required": false,
      "default": "3.0",
      "description": {
        "zh": "误差棒帽大小 (以点为单位)。",
        "en": "Error bar capsize (in points)."
      }
    },
    {
      "name": "--markers",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "为数据点使用默认标记。",
        "en": "Use default markers for data points."
      }
    },
    {
      "name": "--marker-style",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "指定标记符号 (逗号分隔, 例如 'o,s')。覆盖 --markers。",
        "en": "Specific marker symbols (comma-separated, e.g. 'o,s'). Overrides --markers."
      }
    },
    {
      "name": "--dashes",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "为线条使用虚线样式。",
        "en": "Use dashes for lines."
      }
    },
    {
      "name": "--smooth",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "启用平滑曲线拟合。",
        "en": "Enable smooth curve fitting."
      }
    },
    {
      "name": "--smooth-points",
      "type": "int",
      "required": false,
      "default": "300",
      "description": {
        "zh": "插值点数。",
        "en": "Number of points for interpolation."
      }
    }
  ]
}
