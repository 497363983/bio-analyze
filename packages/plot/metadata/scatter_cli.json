{
  "name": "scatter",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "X 轴列名。",
        "en": "Column name for X-axis."
      }
    },
    {
      "name": "--y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Y 轴列名。",
        "en": "Column name for Y-axis."
      }
    },
    {
      "name": "--hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名 (hue)。",
        "en": "Grouping column name (hue)."
      }
    },
    {
      "name": "--style",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "标记样式列名。",
        "en": "Column name for marker style."
      }
    },
    {
      "name": "--size",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "标记大小列名。",
        "en": "Column name for marker size."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--add-ellipse",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "为每个分组绘制置信椭圆。",
        "en": "Draw confidence ellipses for each group."
      }
    },
    {
      "name": "--ellipse-std",
      "type": "float",
      "required": false,
      "default": "2.0",
      "description": {
        "zh": "置信椭圆的标准差。",
        "en": "Standard deviation for confidence ellipses."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    }
  ]
}
