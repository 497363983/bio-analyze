{
  "name": "line",
  "type": "api",
  "description": {
    "zh": "Plot line chart.",
    "en": "Plot line chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for x-axis.",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for y-axis.",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for grouping.",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X-axis label.",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y-axis label.",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "error_bar_type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Error bar type (SD, SE, CI).",
        "en": "Error bar type (SD, SE, CI)."
      }
    },
    {
      "name": "error_bar_ci",
      "type": "int",
      "required": false,
      "default": "95",
      "description": {
        "zh": "Confidence interval size when type is CI (default 95).",
        "en": "Confidence interval size when type is CI (default 95)."
      }
    },
    {
      "name": "error_bar_max",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for error bar upper bound (placeholder, manual drawing not supported yet).",
        "en": "Column name for error bar upper bound (placeholder, manual drawing not supported yet)."
      }
    },
    {
      "name": "error_bar_min",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for error bar lower bound (placeholder, manual drawing not supported yet).",
        "en": "Column name for error bar lower bound (placeholder, manual drawing not supported yet)."
      }
    },
    {
      "name": "error_bar_capsize",
      "type": "float",
      "required": false,
      "default": "3.0",
      "description": {
        "zh": "Width of error bar caps (unit: points).",
        "en": "Width of error bar caps (unit: points)."
      }
    },
    {
      "name": "err_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Error bar color.",
        "en": "Error bar color."
      }
    },
    {
      "name": "cap_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Error bar cap color (usually same as err_color for lineplot).",
        "en": "Error bar cap color (usually same as err_color for lineplot)."
      }
    },
    {
      "name": "markers",
      "type": "bool",
      "required": false,
      "default": null,
      "description": {
        "zh": "Whether to show data point markers, or specify marker style.",
        "en": "Whether to show data point markers, or specify marker style."
      }
    },
    {
      "name": "dashes",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "Whether to show dashes, or specify dash style.",
        "en": "Whether to show dashes, or specify dash style."
      }
    },
    {
      "name": "smooth",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to enable smooth curve fitting.",
        "en": "Whether to enable smooth curve fitting."
      }
    },
    {
      "name": "smooth_points",
      "type": "int",
      "required": false,
      "default": "300",
      "description": {
        "zh": "Number of interpolation points for smooth curve.",
        "en": "Number of interpolation points for smooth curve."
      }
    }
  ]
}