{
  "name": "line",
  "type": "api",
  "description": {
    "zh": "绘制折线图。",
    "en": "Plot line chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "error_bar_type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒类型 (SD, SE, CI)。",
        "en": "Error bar type (SD, SE, CI)."
      }
    },
    {
      "name": "error_bar_ci",
      "type": "int",
      "required": false,
      "default": "95",
      "description": {
        "zh": "当类型为 CI 时的置信区间大小 (默认 95)。",
        "en": "Confidence interval size when type is CI (default 95)."
      }
    },
    {
      "name": "error_bar_max",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒上限的列名 (暂不支持手动绘制，仅占位)。",
        "en": "Column name for error bar upper bound (placeholder, manual drawing not supported yet)."
      }
    },
    {
      "name": "error_bar_min",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒下限的列名 (暂不支持手动绘制，仅占位)。",
        "en": "Column name for error bar lower bound (placeholder, manual drawing not supported yet)."
      }
    },
    {
      "name": "error_bar_capsize",
      "type": "float",
      "required": false,
      "default": "3.0",
      "description": {
        "zh": "误差棒的横线宽度 (单位: points)。",
        "en": "Width of error bar caps (unit: points)."
      }
    },
    {
      "name": "err_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒颜色。",
        "en": "Error bar color."
      }
    },
    {
      "name": "cap_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒横线颜色 (对于 lineplot，通常与 err_color 一致)。",
        "en": "Error bar cap color (usually same as err_color for lineplot)."
      }
    },
    {
      "name": "markers",
      "type": "bool",
      "required": false,
      "default": null,
      "description": {
        "zh": "是否显示数据点标记，或指定标记样式。",
        "en": "Whether to show data point markers, or specify marker style."
      }
    },
    {
      "name": "dashes",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否显示虚线，或指定虚线样式。",
        "en": "Whether to show dashes, or specify dash style."
      }
    },
    {
      "name": "smooth",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否启用平滑曲线拟合。",
        "en": "Whether to enable smooth curve fitting."
      }
    },
    {
      "name": "smooth_points",
      "type": "int",
      "required": false,
      "default": "300",
      "description": {
        "zh": "平滑曲线的插值点数。",
        "en": "Number of interpolation points for smooth curve."
      }
    }
  ]
}