{
  "name": "line",
  "type": "api",
  "description": {
    "zh": "绘制折线图。",
    "en": "绘制折线图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "包含数据的 DataFrame。"
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "x 轴的列名。"
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "y 轴的列名。"
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "分组列名。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X轴标签。"
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y轴标签。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "保存图表的路径。"
      }
    },
    {
      "name": "error_bar_type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒类型 (SD, SE, CI)。",
        "en": "误差棒类型 (SD, SE, CI)。"
      }
    },
    {
      "name": "error_bar_ci",
      "type": "int",
      "required": false,
      "default": "95",
      "description": {
        "zh": "当类型为 CI 时的置信区间大小 (默认 95)。",
        "en": "当类型为 CI 时的置信区间大小 (默认 95)。"
      }
    },
    {
      "name": "error_bar_max",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒上限的列名 (暂不支持手动绘制，仅占位)。",
        "en": "误差棒上限的列名 (暂不支持手动绘制，仅占位)。"
      }
    },
    {
      "name": "error_bar_min",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒下限的列名 (暂不支持手动绘制，仅占位)。",
        "en": "误差棒下限的列名 (暂不支持手动绘制，仅占位)。"
      }
    },
    {
      "name": "error_bar_capsize",
      "type": "float",
      "required": false,
      "default": "3.0",
      "description": {
        "zh": "误差棒的横线宽度 (单位: points)。",
        "en": "误差棒的横线宽度 (单位: points)。"
      }
    },
    {
      "name": "err_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒颜色。",
        "en": "误差棒颜色。"
      }
    },
    {
      "name": "cap_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒横线颜色 (对于 lineplot，通常与 err_color 一致)。",
        "en": "误差棒横线颜色 (对于 lineplot，通常与 err_color 一致)。"
      }
    },
    {
      "name": "markers",
      "type": "bool",
      "required": false,
      "default": null,
      "description": {
        "zh": "是否显示数据点标记，或指定标记样式。",
        "en": "是否显示数据点标记，或指定标记样式。"
      }
    },
    {
      "name": "dashes",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否显示虚线，或指定虚线样式。",
        "en": "是否显示虚线，或指定虚线样式。"
      }
    },
    {
      "name": "smooth",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否启用平滑曲线拟合。",
        "en": "是否启用平滑曲线拟合。"
      }
    },
    {
      "name": "smooth_points",
      "type": "int",
      "required": false,
      "default": "300",
      "description": {
        "zh": "平滑曲线的插值点数。",
        "en": "平滑曲线的插值点数。"
      }
    }
  ]
}