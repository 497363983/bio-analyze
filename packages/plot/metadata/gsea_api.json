{
  "name": "gsea",
  "type": "api",
  "description": {
    "zh": "绘制 GSEA 富集图。",
    "en": "Plot GSEA enrichment plot."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含 GSEA 结果的 DataFrame。",
        "en": "DataFrame containing GSEA results."
      }
    },
    {
      "name": "rank",
      "type": "string",
      "required": false,
      "default": "rank",
      "description": {
        "zh": "排名列名（x 轴）。",
        "en": "Column name for rank (x-axis)."
      }
    },
    {
      "name": "score",
      "type": "string",
      "required": false,
      "default": "running_es",
      "description": {
        "zh": "运行富集分数列名（y 轴顶部）。",
        "en": "Column name for running enrichment score (y-axis top)."
      }
    },
    {
      "name": "hit",
      "type": "string",
      "required": false,
      "default": "hit",
      "description": {
        "zh": "命中状态列名（布尔值或 0/1）。",
        "en": "Column name for hit status (boolean or 0/1)."
      }
    },
    {
      "name": "metric",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "排名指标列名（y 轴底部）。可选。",
        "en": "Column name for ranking metric (y-axis bottom). Optional."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Path to output file."
      }
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "default": "#4DAF4A",
      "description": {
        "zh": "富集分数线的颜色。",
        "en": "Color of the enrichment score line."
      }
    },
    {
      "name": "hit_color",
      "type": "string",
      "required": false,
      "default": "black",
      "description": {
        "zh": "命中垂直线的颜色。",
        "en": "Color of the hit vertical lines."
      }
    },
    {
      "name": "nes",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "标准化富集评分（用于注释）。",
        "en": "Normalized Enrichment Score (for annotation)."
      }
    },
    {
      "name": "pvalue",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "P 值（用于注释）。",
        "en": "P-value (for annotation)."
      }
    },
    {
      "name": "fdr",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "FDR/调整后的 P 值（用于注释）。",
        "en": "FDR/Adjusted P-value (for annotation)."
      }
    },
    {
      "name": "show_border",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否显示子图的顶部和右侧边框。默认为 True。",
        "en": "Whether to show top and right borders of subplots. Defaults to True."
      }
    }
  ]
}
