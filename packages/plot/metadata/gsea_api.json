{
  "name": "gsea",
  "type": "api",
  "description": {
    "zh": "Plot GSEA enrichment plot.",
    "en": "Plot GSEA enrichment plot."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing GSEA results.",
        "en": "DataFrame containing GSEA results."
      }
    },
    {
      "name": "rank",
      "type": "string",
      "required": false,
      "default": "rank",
      "description": {
        "zh": "Column name for rank (x-axis).",
        "en": "Column name for rank (x-axis)."
      }
    },
    {
      "name": "score",
      "type": "string",
      "required": false,
      "default": "running_es",
      "description": {
        "zh": "Column name for running enrichment score (y-axis top).",
        "en": "Column name for running enrichment score (y-axis top)."
      }
    },
    {
      "name": "hit",
      "type": "string",
      "required": false,
      "default": "hit",
      "description": {
        "zh": "Column name for hit status (boolean or 0/1).",
        "en": "Column name for hit status (boolean or 0/1)."
      }
    },
    {
      "name": "metric",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for ranking metric (y-axis bottom). Optional.",
        "en": "Column name for ranking metric (y-axis bottom). Optional."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to output file.",
        "en": "Path to output file."
      }
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "default": "#4DAF4A",
      "description": {
        "zh": "Color of the enrichment score line.",
        "en": "Color of the enrichment score line."
      }
    },
    {
      "name": "hit_color",
      "type": "string",
      "required": false,
      "default": "black",
      "description": {
        "zh": "Color of the hit vertical lines.",
        "en": "Color of the hit vertical lines."
      }
    },
    {
      "name": "nes",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "Normalized Enrichment Score (for annotation).",
        "en": "Normalized Enrichment Score (for annotation)."
      }
    },
    {
      "name": "pvalue",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "P-value (for annotation).",
        "en": "P-value (for annotation)."
      }
    },
    {
      "name": "fdr",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "FDR/Adjusted P-value (for annotation).",
        "en": "FDR/Adjusted P-value (for annotation)."
      }
    },
    {
      "name": "show_border",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "Whether to show top and right borders of subplots. Defaults to True.",
        "en": "Whether to show top and right borders of subplots. Defaults to True."
      }
    }
  ]
}