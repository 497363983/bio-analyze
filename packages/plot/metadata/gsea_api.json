{
  "name": "gsea",
  "type": "api",
  "description": {
    "zh": "绘制 GSEA 富集图。",
    "en": "绘制 GSEA 富集图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含 GSEA 结果的 DataFrame。",
        "en": "包含 GSEA 结果的 DataFrame。"
      }
    },
    {
      "name": "rank",
      "type": "string",
      "required": false,
      "default": "rank",
      "description": {
        "zh": "排名列名（x 轴）。",
        "en": "排名列名（x 轴）。"
      }
    },
    {
      "name": "score",
      "type": "string",
      "required": false,
      "default": "running_es",
      "description": {
        "zh": "运行富集分数列名（y 轴顶部）。",
        "en": "运行富集分数列名（y 轴顶部）。"
      }
    },
    {
      "name": "hit",
      "type": "string",
      "required": false,
      "default": "hit",
      "description": {
        "zh": "命中状态列名（布尔值或 0/1）。",
        "en": "命中状态列名（布尔值或 0/1）。"
      }
    },
    {
      "name": "metric",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "排名指标列名（y 轴底部）。可选。",
        "en": "排名指标列名（y 轴底部）。可选。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "输出文件路径。"
      }
    },
    {
      "name": "color",
      "type": "string",
      "required": false,
      "default": "#4DAF4A",
      "description": {
        "zh": "富集分数线的颜色。",
        "en": "富集分数线的颜色。"
      }
    },
    {
      "name": "hit_color",
      "type": "string",
      "required": false,
      "default": "black",
      "description": {
        "zh": "命中垂直线的颜色。",
        "en": "命中垂直线的颜色。"
      }
    },
    {
      "name": "nes",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "标准化富集评分（用于注释）。",
        "en": "标准化富集评分（用于注释）。"
      }
    },
    {
      "name": "pvalue",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "P 值（用于注释）。",
        "en": "P 值（用于注释）。"
      }
    },
    {
      "name": "fdr",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "FDR/调整后的 P 值（用于注释）。",
        "en": "FDR/调整后的 P 值（用于注释）。"
      }
    },
    {
      "name": "show_border",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否显示子图的顶部和右侧边框。默认为 True。",
        "en": "是否显示子图的顶部和右侧边框。默认为 True。"
      }
    }
  ]
}