{
  "name": "heatmap",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--index-col",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "用作行索引的列。",
        "en": "Column to use as row index."
      }
    },
    {
      "name": "--cluster-rows",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否聚类行。",
        "en": "Whether to cluster rows."
      }
    },
    {
      "name": "--cluster-cols",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否聚类列。",
        "en": "Whether to cluster columns."
      }
    },
    {
      "name": "--z-score",
      "type": "int",
      "required": false,
      "default": null,
      "description": {
        "zh": "标准化 (0: 行, 1: 列)。None 禁用。",
        "en": "0 (rows) or 1 (columns) for standardization. None to disable."
      }
    },
    {
      "name": "--cmap",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "颜色映射名称 (例如 'vlag', 'coolwarm')。",
        "en": "Colormap name (e.g. 'vlag', 'coolwarm')."
      }
    },
    {
      "name": "--center",
      "type": "float",
      "required": false,
      "default": null,
      "description": {
        "zh": "颜色映射居中的值。",
        "en": "Value at which to center the colormap."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    }
  ]
}