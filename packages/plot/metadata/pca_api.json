{
  "name": "pca",
  "type": "api",
  "description": {
    "zh": "生成 PCA 图。",
    "en": "生成 PCA 图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数值数据的 DataFrame。",
        "en": "包含数值数据的 DataFrame。"
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "",
        "en": ""
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "",
        "en": ""
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组信息。可以是 data 中的列名（如果 transpose=False），\n或者是与样本匹配的值列表/Series（如果 transpose=True）。",
        "en": "分组信息。可以是 data 中的列名（如果 transpose=False），\n或者是与样本匹配的值列表/Series（如果 transpose=True）。"
      }
    },
    {
      "name": "index_col",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "用作索引的列（例如基因 ID）。",
        "en": "用作索引的列（例如基因 ID）。"
      }
    },
    {
      "name": "transpose",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否转置 dataframe。\n通常表达矩阵是 基因 x 样本。\nPCA 需要 样本 x 基因。所以默认为 True。",
        "en": "是否转置 dataframe。\n通常表达矩阵是 基因 x 样本。\nPCA 需要 样本 x 基因。所以默认为 True。"
      }
    },
    {
      "name": "n_components",
      "type": "int",
      "required": false,
      "default": "2",
      "description": {
        "zh": "组件数量（默认 2）。",
        "en": "组件数量（默认 2）。"
      }
    },
    {
      "name": "cluster",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "如果为 True，则围绕 hue 定义的组绘制置信椭圆。",
        "en": "如果为 True，则围绕 hue 定义的组绘制置信椭圆。"
      }
    },
    {
      "name": "n_clusters",
      "type": "int",
      "required": false,
      "default": "3",
      "description": {
        "zh": "已弃用/忽略。椭圆是基于 'hue' 分组绘制的。",
        "en": "已弃用/忽略。椭圆是基于 'hue' 分组绘制的。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "",
        "en": ""
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X轴标签。"
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y轴标签。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": "pca.png",
      "description": {
        "zh": "",
        "en": ""
      }
    }
  ]
}