{
  "name": "pca",
  "type": "api",
  "description": {
    "zh": "生成 PCA 图。",
    "en": "Generate PCA plot."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数值数据的 DataFrame。",
        "en": "DataFrame containing numerical data."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组信息。可以是 data 中的列名（如果 transpose=False），或者是与样本匹配的值列表/Series（如果 transpose=True）。",
        "en": "Grouping info. Can be column name in data (if transpose=False), or list/Series matching samples (if transpose=True)."
      }
    },
    {
      "name": "index_col",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "用作索引的列（例如基因 ID）。",
        "en": "Column to use as index (e.g. Gene ID)."
      }
    },
    {
      "name": "transpose",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否转置 dataframe。通常表达矩阵是 基因 x 样本。PCA 需要 样本 x 基因。所以默认为 True。",
        "en": "Whether to transpose dataframe. Usually expression matrix is Gene x Sample. PCA needs Sample x Gene. So defaults to True."
      }
    },
    {
      "name": "n_components",
      "type": "int",
      "required": false,
      "default": "2",
      "description": {
        "zh": "组件数量（默认 2）。",
        "en": "Number of components (default 2)."
      }
    },
    {
      "name": "cluster",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "如果为 True，则围绕 hue 定义的组绘制置信椭圆。",
        "en": "If True, draw confidence ellipses around groups defined by hue."
      }
    },
    {
      "name": "n_clusters",
      "type": "int",
      "required": false,
      "default": "3",
      "description": {
        "zh": "已弃用/忽略。椭圆是基于 'hue' 分组绘制的。",
        "en": "Deprecated/Ignored. Ellipses are drawn based on 'hue' grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": "pca.png",
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    }
  ]
}
