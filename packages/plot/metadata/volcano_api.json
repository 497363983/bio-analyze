{
  "name": "volcano",
  "type": "api",
  "description": {
    "zh": "绘制火山图。",
    "en": "绘制火山图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "包含数据的 DataFrame。"
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": false,
      "default": "log2FoldChange",
      "description": {
        "zh": "log2 fold change 的列名。",
        "en": "log2 fold change 的列名。"
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": false,
      "default": "pvalue",
      "description": {
        "zh": "p-value (或 adj. p-value) 的列名。",
        "en": "p-value (或 adj. p-value) 的列名。"
      }
    },
    {
      "name": "log_y",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否对 y 轴进行 -log10 转换。",
        "en": "是否对 y 轴进行 -log10 转换。"
      }
    },
    {
      "name": "fc_cutoff",
      "type": "float",
      "required": false,
      "default": "1.0",
      "description": {
        "zh": "Fold change 截止值 (绝对值)。",
        "en": "Fold change 截止值 (绝对值)。"
      }
    },
    {
      "name": "p_cutoff",
      "type": "float",
      "required": false,
      "default": "0.05",
      "description": {
        "zh": "P-value 截止值。",
        "en": "P-value 截止值。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X轴标签。"
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y轴标签。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "保存图表的路径。"
      }
    },
    {
      "name": "labels",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "自定义图例标签，字典格式，键为 \"up\", \"down\", \"ns\"。\n默认为 {\"up\": \"Up\", \"down\": \"Down\", \"ns\": \"Not Sig\"}。",
        "en": "自定义图例标签，字典格式，键为 \"up\", \"down\", \"ns\"。\n默认为 {\"up\": \"Up\", \"down\": \"Down\", \"ns\": \"Not Sig\"}。"
      }
    }
  ]
}