{
  "name": "volcano",
  "type": "api",
  "description": {
    "zh": "绘制火山图。",
    "en": "Plot volcano plot."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": false,
      "default": "log2FoldChange",
      "description": {
        "zh": "log2 fold change 的列名。",
        "en": "Column name for log2 fold change."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": false,
      "default": "pvalue",
      "description": {
        "zh": "p-value (或 adj. p-value) 的列名。",
        "en": "Column name for p-value (or adj. p-value)."
      }
    },
    {
      "name": "log_y",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "是否对 y 轴进行 -log10 转换。",
        "en": "Whether to apply -log10 transformation to y-axis."
      }
    },
    {
      "name": "fc_cutoff",
      "type": "float",
      "required": false,
      "default": "1.0",
      "description": {
        "zh": "Fold change 截止值 (绝对值)。",
        "en": "Fold change cutoff value (absolute)."
      }
    },
    {
      "name": "p_cutoff",
      "type": "float",
      "required": false,
      "default": "0.05",
      "description": {
        "zh": "P-value 截止值。",
        "en": "P-value cutoff value."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "labels",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "自定义图例标签，字典格式，键为 \"up\", \"down\", \"ns\"。\n默认为 {\"up\": \"Up\", \"down\": \"Down\", \"ns\": \"Not Sig\"}。",
        "en": "Custom legend labels, dict with keys \"up\", \"down\", \"ns\".\nDefaults to {\"up\": \"Up\", \"down\": \"Down\", \"ns\": \"Not Sig\"}."
      }
    }
  ]
}
