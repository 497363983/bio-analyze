{
  "name": "volcano",
  "type": "api",
  "description": {
    "zh": "Plot volcano plot.",
    "en": "Plot volcano plot."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": false,
      "default": "log2FoldChange",
      "description": {
        "zh": "Column name for log2 fold change.",
        "en": "Column name for log2 fold change."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": false,
      "default": "pvalue",
      "description": {
        "zh": "Column name for p-value (or adj. p-value).",
        "en": "Column name for p-value (or adj. p-value)."
      }
    },
    {
      "name": "log_y",
      "type": "bool",
      "required": false,
      "default": "True",
      "description": {
        "zh": "Whether to apply -log10 transformation to y-axis.",
        "en": "Whether to apply -log10 transformation to y-axis."
      }
    },
    {
      "name": "fc_cutoff",
      "type": "float",
      "required": false,
      "default": "1.0",
      "description": {
        "zh": "Fold change cutoff value (absolute).",
        "en": "Fold change cutoff value (absolute)."
      }
    },
    {
      "name": "p_cutoff",
      "type": "float",
      "required": false,
      "default": "0.05",
      "description": {
        "zh": "P-value cutoff value.",
        "en": "P-value cutoff value."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X-axis label.",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y-axis label.",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "labels",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Custom legend labels, dict with keys \"up\", \"down\", \"ns\".\nDefaults to {\"up\": \"Up\", \"down\": \"Down\", \"ns\": \"Not Sig\"}.",
        "en": "Custom legend labels, dict with keys \"up\", \"down\", \"ns\".\nDefaults to {\"up\": \"Up\", \"down\": \"Down\", \"ns\": \"Not Sig\"}."
      }
    }
  ]
}