{
  "name": "pie",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "标签列名 (分类变量)。",
        "en": "Column name for labels (categorical)."
      }
    },
    {
      "name": "--y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "数值列名。",
        "en": "Column name for values (numerical)."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--autopct",
      "type": "string",
      "required": false,
      "default": "%1.1f%%",
      "description": {
        "zh": "百分比格式。",
        "en": "Percentage format."
      }
    },
    {
      "name": "--startangle",
      "type": "float",
      "required": false,
      "default": "90",
      "description": {
        "zh": "起始角度。",
        "en": "Start angle."
      }
    },
    {
      "name": "--explode",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "扇区偏移。可以是列名或逗号分隔的数值。",
        "en": "Explode slices. Can be a column name or comma-separated values."
      }
    },
    {
      "name": "--shadow",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "显示阴影。",
        "en": "Show shadow."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    }
  ]
}