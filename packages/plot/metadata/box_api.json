{
  "name": "box",
  "type": "api",
  "description": {
    "zh": "绘制箱线图。",
    "en": "Plot box chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "要进行显著性检验的配对列表。",
        "en": "List of pairs for significance testing."
      }
    },
    {
      "name": "test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "统计检验方法。",
        "en": "Statistical test method."
      }
    },
    {
      "name": "text_format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "显著性标记格式。",
        "en": "Significance annotation format."
      }
    },
    {
      "name": "add_swarm",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否叠加散点图 (swarmplot)。",
        "en": "Whether to overlay swarmplot."
      }
    },
    {
      "name": "swarm_color",
      "type": "string",
      "required": false,
      "default": ".25",
      "description": {
        "zh": "散点颜色。",
        "en": "Color of swarm points."
      }
    },
    {
      "name": "swarm_size",
      "type": "float",
      "required": false,
      "default": "3",
      "description": {
        "zh": "散点大小。",
        "en": "Size of swarm points."
      }
    }
  ]
}