{
  "name": "box",
  "type": "api",
  "description": {
    "zh": "绘制箱线图。",
    "en": "绘制箱线图。"
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "包含数据的 DataFrame。"
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "x 轴的列名。"
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "y 轴的列名。"
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "分组列名。"
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "图表标题。"
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X轴标签。"
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y轴标签。"
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "保存图表的路径。"
      }
    },
    {
      "name": "significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "要进行显著性检验的配对列表。",
        "en": "要进行显著性检验的配对列表。"
      }
    },
    {
      "name": "test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "统计检验方法。",
        "en": "统计检验方法。"
      }
    },
    {
      "name": "text_format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "显著性标记格式。",
        "en": "显著性标记格式。"
      }
    },
    {
      "name": "add_swarm",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "是否叠加散点图 (swarmplot)。",
        "en": "是否叠加散点图 (swarmplot)。"
      }
    },
    {
      "name": "swarm_color",
      "type": "string",
      "required": false,
      "default": ".25",
      "description": {
        "zh": "散点颜色。",
        "en": "散点颜色。"
      }
    },
    {
      "name": "swarm_size",
      "type": "float",
      "required": false,
      "default": "3",
      "description": {
        "zh": "散点大小。",
        "en": "散点大小。"
      }
    }
  ]
}