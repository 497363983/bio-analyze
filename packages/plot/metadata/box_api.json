{
  "name": "box",
  "type": "api",
  "description": {
    "zh": "Plot box chart.",
    "en": "Plot box chart."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for x-axis.",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for y-axis.",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for grouping.",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X-axis label.",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y-axis label.",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "List of pairs for significance testing.",
        "en": "List of pairs for significance testing."
      }
    },
    {
      "name": "test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "Statistical test method.",
        "en": "Statistical test method."
      }
    },
    {
      "name": "text_format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "Significance annotation format.",
        "en": "Significance annotation format."
      }
    },
    {
      "name": "add_swarm",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": {
        "zh": "Whether to overlay swarmplot.",
        "en": "Whether to overlay swarmplot."
      }
    },
    {
      "name": "swarm_color",
      "type": "string",
      "required": false,
      "default": ".25",
      "description": {
        "zh": "Color of swarm points.",
        "en": "Color of swarm points."
      }
    },
    {
      "name": "swarm_size",
      "type": "float",
      "required": false,
      "default": "3",
      "description": {
        "zh": "Size of swarm points.",
        "en": "Size of swarm points."
      }
    }
  ]
}