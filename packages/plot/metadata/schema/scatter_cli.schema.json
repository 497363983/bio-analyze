{
  "name": "scatter",
  "type": "cli",
  "description": "Generate scatter plot.",
  "params": [
    {
      "field": "input_file",
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": "Input file path (CSV, TSV, or Excel)."
    },
    {
      "field": "output",
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": "Output file path."
    },
    {
      "field": "x",
      "name": "--x",
      "type": "string",
      "required": true,
      "default": null,
      "description": "Column name for X-axis."
    },
    {
      "field": "y",
      "name": "--y",
      "type": "string",
      "required": true,
      "default": null,
      "description": "Column name for Y-axis."
    },
    {
      "field": "hue",
      "name": "--hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": "Grouping column name (hue)."
    },
    {
      "field": "style",
      "name": "--style",
      "type": "string",
      "required": false,
      "default": null,
      "description": "Column name for marker style."
    },
    {
      "field": "size",
      "name": "--size",
      "type": "string",
      "required": false,
      "default": null,
      "description": "Column name for marker size."
    },
    {
      "field": "theme",
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
    },
    {
      "field": "title",
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": "Plot title."
    },
    {
      "field": "add_ellipse",
      "name": "--add-ellipse",
      "type": "bool",
      "required": false,
      "default": "False",
      "description": "Draw confidence ellipses for each group."
    },
    {
      "field": "ellipse_std",
      "name": "--ellipse-std",
      "type": "float",
      "required": false,
      "default": "2.0",
      "description": "Standard deviation for confidence ellipses."
    },
    {
      "field": "sheet",
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": "Sheet name for Excel files."
    }
  ]
}