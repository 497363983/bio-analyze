{
  "name": "bar",
  "type": "cli",
  "description": {
    "zh": "",
    "en": ""
  },
  "params": [
    {
      "name": "--input-file",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输入文件路径 (CSV, TSV 或 Excel)。",
        "en": "Input file path (CSV, TSV, or Excel)."
      }
    },
    {
      "name": "-o, --output",
      "type": "path",
      "required": true,
      "default": null,
      "description": {
        "zh": "输出文件路径。",
        "en": "Output file path."
      }
    },
    {
      "name": "--x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "X 轴列名。",
        "en": "Column name for X-axis."
      }
    },
    {
      "name": "--y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Y 轴列名。",
        "en": "Column name for Y-axis."
      }
    },
    {
      "name": "--hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名 (hue)。",
        "en": "Grouping column name (hue)."
      }
    },
    {
      "name": "--theme",
      "type": "string",
      "required": false,
      "default": "nature",
      "description": {
        "zh": "绘图主题 (nature, science, default) 或自定义主题路径 (.json/.py)。",
        "en": "Plot theme (nature, science, default) or path to custom theme (.json/.py)."
      }
    },
    {
      "name": "--title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Plot title."
      }
    },
    {
      "name": "--error-bar-type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒类型: SD, SE, CI。",
        "en": "Error bar type: SD, SE, CI."
      }
    },
    {
      "name": "--error-bar-ci",
      "type": "float",
      "required": false,
      "default": "95",
      "description": {
        "zh": "置信区间大小 (默认: 95)。",
        "en": "Confidence interval size (default: 95)."
      }
    },
    {
      "name": "--error-bar-max",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒上限列名。",
        "en": "Column name for error bar upper limit."
      }
    },
    {
      "name": "--error-bar-min",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒下限列名。",
        "en": "Column name for error bar lower limit."
      }
    },
    {
      "name": "--error-bar-capsize",
      "type": "float",
      "required": false,
      "default": "0.1",
      "description": {
        "zh": "误差棒帽大小。",
        "en": "Error bar capsize."
      }
    },
    {
      "name": "--significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "显著性检验配对 (例如 'A,B' 'C,D')。",
        "en": "Pairs for significance testing (e.g. 'A,B' 'C,D')."
      }
    },
    {
      "name": "--test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "统计检验方法。",
        "en": "Statistical test method."
      }
    },
    {
      "name": "--text-format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "显著性标注格式。",
        "en": "Significance annotation format."
      }
    },
    {
      "name": "--sheet",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Excel 工作表名称。",
        "en": "Sheet name for Excel files."
      }
    }
  ]
}