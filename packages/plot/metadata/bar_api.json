{
  "name": "bar",
  "type": "api",
  "description": {
    "zh": "Plot bar chart with error bars.",
    "en": "Plot bar chart with error bars."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "DataFrame containing data.",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for x-axis.",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "Column name for y-axis.",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for grouping.",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Chart title.",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X-axis label.",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y-axis label.",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Path to save the chart.",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "error_bar_type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Error bar type (SD, SE, CI). Ignored if max/min are provided.",
        "en": "Error bar type (SD, SE, CI). Ignored if max/min are provided."
      }
    },
    {
      "name": "error_bar_ci",
      "type": "int",
      "required": false,
      "default": "95",
      "description": {
        "zh": "Confidence interval size when type is CI (default 95).",
        "en": "Confidence interval size when type is CI (default 95)."
      }
    },
    {
      "name": "error_bar_max",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for error bar upper bound.",
        "en": "Column name for error bar upper bound."
      }
    },
    {
      "name": "error_bar_min",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Column name for error bar lower bound.",
        "en": "Column name for error bar lower bound."
      }
    },
    {
      "name": "error_bar_capsize",
      "type": "float",
      "required": false,
      "default": "0.1",
      "description": {
        "zh": "Width of error bar caps.",
        "en": "Width of error bar caps."
      }
    },
    {
      "name": "significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "List of pairs for significance testing. E.g. [(\"A\", \"B\"), (\"C\", \"D\")].\nIf grouped bar plot (with hue), format is [((x1, hue1), (x2, hue2)), ...].",
        "en": "List of pairs for significance testing. E.g. [(\"A\", \"B\"), (\"C\", \"D\")].\nIf grouped bar plot (with hue), format is [((x1, hue1), (x2, hue2)), ...]."
      }
    },
    {
      "name": "test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "Statistical test method. Supports 't-test_ind', 't-test_welch', 't-test_paired', 'Mann-Whitney', 'Wilcoxon', 'Kruskal'.",
        "en": "Statistical test method. Supports 't-test_ind', 't-test_welch', 't-test_paired', 'Mann-Whitney', 'Wilcoxon', 'Kruskal'."
      }
    },
    {
      "name": "text_format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "Significance annotation format ('star', 'full', 'simple', 'pvalue').",
        "en": "Significance annotation format ('star', 'full', 'simple', 'pvalue')."
      }
    },
    {
      "name": "err_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Error bar color.",
        "en": "Error bar color."
      }
    },
    {
      "name": "cap_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Error bar cap color.",
        "en": "Error bar cap color."
      }
    }
  ]
}