{
  "name": "bar",
  "type": "api",
  "description": {
    "zh": "绘制带有误差棒的柱状图。",
    "en": "Plot bar chart with error bars."
  },
  "params": [
    {
      "name": "data",
      "type": "DataFrame",
      "required": true,
      "default": null,
      "description": {
        "zh": "包含数据的 DataFrame。",
        "en": "DataFrame containing data."
      }
    },
    {
      "name": "x",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "x 轴的列名。",
        "en": "Column name for x-axis."
      }
    },
    {
      "name": "y",
      "type": "string",
      "required": true,
      "default": null,
      "description": {
        "zh": "y 轴的列名。",
        "en": "Column name for y-axis."
      }
    },
    {
      "name": "hue",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "分组列名。",
        "en": "Column name for grouping."
      }
    },
    {
      "name": "title",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "图表标题。",
        "en": "Chart title."
      }
    },
    {
      "name": "xlabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "X轴标签。",
        "en": "X-axis label."
      }
    },
    {
      "name": "ylabel",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "Y轴标签。",
        "en": "Y-axis label."
      }
    },
    {
      "name": "output",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "保存图表的路径。",
        "en": "Path to save the chart."
      }
    },
    {
      "name": "error_bar_type",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒类型 (SD, SE, CI)。如果提供了 max/min 则忽略。",
        "en": "Error bar type (SD, SE, CI). Ignored if max/min are provided."
      }
    },
    {
      "name": "error_bar_ci",
      "type": "int",
      "required": false,
      "default": "95",
      "description": {
        "zh": "当类型为 CI 时的置信区间大小 (默认 95)。",
        "en": "Confidence interval size when type is CI (default 95)."
      }
    },
    {
      "name": "error_bar_max",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒上限的列名。",
        "en": "Column name for error bar upper bound."
      }
    },
    {
      "name": "error_bar_min",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒下限的列名。",
        "en": "Column name for error bar lower bound."
      }
    },
    {
      "name": "error_bar_capsize",
      "type": "float",
      "required": false,
      "default": "0.1",
      "description": {
        "zh": "误差棒的横线宽度。",
        "en": "Width of error bar caps."
      }
    },
    {
      "name": "significance",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "要进行显著性检验的配对列表。例如 [(\"A\", \"B\"), (\"C\", \"D\")]。\n如果是分组柱状图 (有 hue)，则格式为 [((x1, hue1), (x2, hue2)), ...]。",
        "en": "List of pairs for significance testing. E.g. [(\"A\", \"B\"), (\"C\", \"D\")].\nIf grouped bar plot (with hue), format is [((x1, hue1), (x2, hue2)), ...]."
      }
    },
    {
      "name": "test",
      "type": "string",
      "required": false,
      "default": "t-test_ind",
      "description": {
        "zh": "统计检验方法。支持 't-test_ind', 't-test_welch', 't-test_paired', 'Mann-Whitney', 'Wilcoxon', 'Kruskal'。",
        "en": "Statistical test method. Supports 't-test_ind', 't-test_welch', 't-test_paired', 'Mann-Whitney', 'Wilcoxon', 'Kruskal'."
      }
    },
    {
      "name": "text_format",
      "type": "string",
      "required": false,
      "default": "star",
      "description": {
        "zh": "显著性标记格式 ('star', 'full', 'simple', 'pvalue')。",
        "en": "Significance annotation format ('star', 'full', 'simple', 'pvalue')."
      }
    },
    {
      "name": "err_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒颜色。",
        "en": "Error bar color."
      }
    },
    {
      "name": "cap_color",
      "type": "string",
      "required": false,
      "default": null,
      "description": {
        "zh": "误差棒横线颜色。",
        "en": "Error bar cap color."
      }
    }
  ]
}
