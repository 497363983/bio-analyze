[project]
name = "bio_analyze_{{name}}"
version = "0.1.0"
description = "BioAnalyze {{name}} module"
dependencies = [
    "bio-analyze-core",
    "typer>=0.9.0",
]
requires-python = ">=3.10"

[project.entry-points."bio_analyze.plugins"]
{{name}} = "bio_analyze_{{name}}.cli:get_app"

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
